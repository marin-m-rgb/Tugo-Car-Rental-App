<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="12dp">

    <ImageView
        android:id="@+id/owner_car_profile_photo_list_item_imageview"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/owner_car_brand_model_list_item_textview"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Tesla Model 3"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2f2f2f"/>

        <TextView
            android:id="@+id/owner_car_price_per_day_list_item_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$190/day"
            android:textSize="18sp"
            android:textColor="#2f2f2f"/>
    </LinearLayout>

    <TextView
        android:id="@+id/owner_car_license_plate_list_item_textview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ABC123"
        android:textSize="18sp"
        android:textColor="#2f2f2f"/>

</LinearLayout>