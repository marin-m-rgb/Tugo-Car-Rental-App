<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:gravity="center_horizontal"
    android:layout_marginBottom="12dp">


    <LinearLayout
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/renter_confirmation_code_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Code: TUGO-12345"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2f2f2f"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/renter_car_license_plate_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plate: ABC123"
            android:textSize="16sp"
            android:textColor="#2f2f2f"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/renter_car_brand_model_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tesla Model 2"
            android:textSize="16sp"
            android:textColor="#2f2f2f"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/renter_car_color_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Black"
            android:textSize="16sp"
            android:textColor="#2f2f2f"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/renter_car_address_city_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="123 Main St, Toronto"
            android:textSize="16sp"
            android:textColor="#2f2f2f"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/renter_start_end_rent_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 Dec 2025 - 24 Dec 2025"
            android:textSize="16sp"
            android:textColor="#2f2f2f"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/renter_cancel_booking_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:backgroundTint="#000000"
            android:layout_gravity="center_horizontal"/>
    </LinearLayout>

</LinearLayout>